{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "ycloud-ui",
  "homepage": "https://github.com/wushiji1995/ycloud-ui",
  "items": [
    {
      "name": "theme",
      "type": "registry:style",
      "title": "YCloud UI theme",
      "description": "Shared Tailwind CSS 4 layers and YCloud UI design tokens without Tailwind preflight.",
      "dependencies": ["tailwindcss", "tw-animate-css"],
      "devDependencies": ["@tailwindcss/postcss", "shadcn"],
      "files": [
        {
          "path": "src/styles/ycloud-ui.css",
          "type": "registry:style",
          "target": "src/styles/ycloud-ui.css"
        }
      ]
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "YCloud utils",
      "description": "Shared utility helpers for YCloud UI components.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "src/lib/utils.ts",
          "type": "registry:lib",
          "target": "src/lib/utils.ts"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "YCloud Button",
      "description": "YCloud button component based on Base UI and class-variance-authority.",
      "dependencies": ["@base-ui/react", "class-variance-authority"],
      "registryDependencies": [
        "wushiji1995/ycloud-ui/theme",
        "wushiji1995/ycloud-ui/utils",
        "wushiji1995/ycloud-ui/spinner"
      ],
      "files": [
        {
          "path": "src/components/ui/button.tsx",
          "type": "registry:ui",
          "target": "src/components/ui/button.tsx"
        }
      ]
    },
    {
      "name": "spinner",
      "type": "registry:ui",
      "title": "YCloud Spinner",
      "description": "YCloud loading spinner for inline button and status indicators.",
      "registryDependencies": ["wushiji1995/ycloud-ui/utils"],
      "files": [
        {
          "path": "src/components/ui/spinner.tsx",
          "type": "registry:ui",
          "target": "src/components/ui/spinner.tsx"
        }
      ]
    },
    {
      "name": "otp-field",
      "type": "registry:ui",
      "title": "YCloud OTP Field",
      "description": "A shadcn-style one-time password field built on the Base UI OTP Field primitive.",
      "dependencies": ["@base-ui/react"],
      "registryDependencies": [
        "wushiji1995/ycloud-ui/theme",
        "wushiji1995/ycloud-ui/utils"
      ],
      "files": [
        {
          "path": "src/components/ui/otp-field.tsx",
          "type": "registry:ui",
          "target": "src/components/ui/otp-field.tsx"
        }
      ]
    }
  ]
}
